# ============================================
# INHAUS MARKETING DATA API — v5.0
# Copy this file to .env and fill in your values
# ============================================
# NOTE: Platform-specific credentials (Meta, Google Ads, TikTok, etc.) 
# are now dynamically resolved per-request via the DataRequest.account_id 
# and the Firestore credential_store for multi-tenancy.
#
# Only system-wide configurations are required in .env.
# ============================================

# ============================================
# API AUTHENTICATION
# ============================================
API_KEY=your_api_key_here

# ============================================
# BIGQUERY SINK (optional)
# ============================================
BIGQUERY_PROJECT_ID=
BIGQUERY_DATASET_ID=marketing_data
BIGQUERY_TABLE_ID=raw_campaign_data
ENABLE_BIGQUERY_SINK=false

# ============================================
# LEGACY / FALLBACK CREDENTIALS (Optional)
# ============================================
# These can be used as global fallbacks, but per-user resolution 
# via Firestore is preferred for production multi-tenancy.
# ============================================
META_ACCESS_TOKEN=
META_APP_ID=
META_APP_SECRET=
META_OAUTH_REDIRECT_URI=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
TIKTOK_ADS_ACCESS_TOKEN=
TIKTOK_ADS_APP_ID=
TIKTOK_ADS_SECRET=
TIKTOK_ACCESS_TOKEN=
LINKEDIN_ACCESS_TOKEN=
X_BEARER_TOKEN=
X_ADS_ACCESS_TOKEN=
YOUTUBE_API_KEY=
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
APPLE_KEY_ID=
APPLE_ISSUER_ID=
APPLE_PRIVATE_KEY_PATH=
APPLE_ADS_ACCESS_TOKEN=
